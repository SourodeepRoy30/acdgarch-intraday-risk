## 2. Package Dependencies

```{r packages}

pkgs <- c(

  # ── Data ingestion and manipulation ──────────────────────────────────────────
  "data.table",    # fast ingestion and manipulation of 1M+ row tick datasets
  "lubridate",     # timezone-aware timestamp parsing and period arithmetic
  "stringr",       # string cleaning for column names and file path handling
  "zoo",           # rolling window operations on irregular time-series

  # ── ACD (duration) modelling ──────────────────────────────────────────────────
  "ACDm",          # Autoregressive Conditional Duration: Weibull and Exp specs

  # ── GARCH (volatility) modelling ──────────────────────────────────────────────
  "rugarch",       # GARCH family (sGARCH, eGARCH, gjrGARCH) with OOS rolling
                   # forecasts via ugarchfit(out.sample) + ugarchforecast(n.roll)

  # ── Statistical testing and diagnostics ───────────────────────────────────────
  "tseries",       # ADF unit root test; Jarque-Bera normality test
  "urca",          # KPSS stationarity test; supplementary unit root tests
  "moments",       # skewness() and kurtosis() for return distribution analysis

  # ── Distribution fitting ───────────────────────────────────────────────────────
  "fitdistrplus",  # MLE fitting of parametric distributions to duration series
                   # used for Weibull vs Exponential ACD innovation diagnostics

  # ── Visualisation ──────────────────────────────────────────────────────────────
  "ggplot2",       # all primary plots throughout the pipeline
  "gridExtra",     # multi-panel layout via grid.arrange()
  "patchwork",     # compositional multi-panel ggplot layout
  "ggplotify",     # converts base R plots to ggplot objects for uniform styling

  # ── Utilities ──────────────────────────────────────────────────────────────────
  "e1071",         # additional skewness/kurtosis: cross-check against moments pkg
  "here"           # resolves file paths relative to .Rproj root — ensures notebooks
                   # run identically on any machine without hardcoded paths

)

# ── Package installation guard ────────────────────────────────────────────────
#
# Interactive sessions (RStudio console): install missing packages automatically.
# Knitting / CI: fail immediately with an actionable error message.
# We never silently install during knitting — this masks environment issues.

missing_pkgs <- pkgs[!vapply(pkgs, requireNamespace, logical(1), quietly = TRUE)]

if (length(missing_pkgs) > 0 && interactive()) {
  message("Installing missing packages: ", paste(missing_pkgs, collapse = ", "))
  install.packages(missing_pkgs, dependencies = TRUE)
}

still_missing <- pkgs[!vapply(pkgs, requireNamespace, logical(1), quietly = TRUE)]

if (length(still_missing) > 0) {
  stop(
    "The following required packages are not installed:\n  ",
    paste(still_missing, collapse = ", "),
    "\n\nTo resolve: run renv::restore() or install the packages manually."
  )
}

# Load all packages quietly — startup messages suppressed for clean HTML output
invisible(lapply(pkgs, function(p) {
  suppressPackageStartupMessages(library(p, character.only = TRUE))
}))

message("All ", length(pkgs), " packages loaded successfully.")

# Confirm here package is anchored to the correct project root.
# You should see the path to your acdgarch-intraday-risk folder.
message("Project root: ", here::here())
```

